# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=StockIQ
PORT=4000

# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/stockiq
MONGODB_URI=mongodb://127.0.0.1:27017/stockiq

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# ─── CORS ────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Data Mode ───────────────────────────────────────────────────────────────
# Set to true to skip all external API calls and use local mock JSON
USE_MOCK_DATA=false

# ─── Gemini (Chat AI) ────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Groq (AI Insights / optional) ─────────────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ─── Market Data APIs ────────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key_here
FMP_API_KEY=your_fmp_api_key_here
NEWS_API_KEY=your_newsapi_org_key_here
GNEWS_API_KEY=your_gnews_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
